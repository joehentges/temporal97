{
  "name": "temporal97",
  "version": "0.1.1",
  "description": "A TypeScript temporal graph with snapshot-based time travel and mutation history tracking.",
  "keywords": [
    "temporal",
    "graph",
    "snapshot",
    "time-travel",
    "mutations",
    "history",
    "typescript",
    "data-structure"
  ],
  "contributors": [
    {
      "name": "Joe Hentges",
      "url": "https://github.com/joehentges"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joehentges/temporal97.git"
  },
  "bugs": {
    "url": "https://github.com/joehentges/temporal97/issues"
  },
  "homepage": "https://github.com/joehentges/temporal97#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "changeset publish",
    "version": "changeset version && npm install --package-lock-only"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
